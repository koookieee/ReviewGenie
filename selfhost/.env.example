# --- Required ---

# Gemini API key. Used by:
#   1. search-api  (computes query embeddings via Gemini's batchEmbedContents)
#   2. review-api  (forwarded into sandboxes so the agent's /app/search CLI can call /query_paper)
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# E2B API key. review-api spawns one E2B sandbox per review request.
# Get one at https://e2b.dev/dashboard
E2B_API_KEY=

# Anthropic-compatible endpoint that the in-sandbox Claude Code agent talks to.
# Either:
#   (a) https://api.anthropic.com  + a real Anthropic key, OR
#   (b) https://api.deepseek.com/anthropic + a DeepSeek key (for `deepseek-v4-pro`/`deepseek-v4-flash`).
# Default in compose is (a).
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_KEY=
# ANTHROPIC_AUTH_TOKEN defaults to ANTHROPIC_API_KEY; only set if your proxy needs a separate one.
# ANTHROPIC_AUTH_TOKEN=

# --- Optional ---

# Host ports the services bind to. Change if 8081/8082 are taken.
# SEARCH_API_PORT=8081
# REVIEW_API_PORT=8082

# Override the URL the review-api passes into E2B sandboxes for the search CLI.
# Default: https://search-api.eigenlabs.online (our hosted endpoint — zero setup)
#
# To run search-api locally and have sandboxes use it, you must expose it to the public
# internet (E2B sandboxes don't share your docker network). Easiest options:
#
#   # Cloudflare Quick Tunnel (no signup):
#   docker run --rm -d --network host cloudflare/cloudflared:latest tunnel --url http://localhost:8081
#
#   # ngrok:
#   ngrok http 8081
#
# Then set:
# SEARCH_PUBLIC_URL=https://your-tunnel-url.example.com
