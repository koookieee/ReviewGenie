#!/usr/bin/env python3
"""Find a figure in /app/latex/template.tex by number or caption keyword.

Returns the figure environment (LaTeX) or the surrounding paragraph with
the image reference and caption (Markdown/plain text).

Usage:
    read_figure 1                   # Figure 1
    read_figure 3                   # Figure 3
    read_figure "architecture"      # first figure whose caption contains "architecture"
    read_figure --list              # list all figures with captions
"""

import argparse
import re
import sys
from pathlib import Path

PAPER = Path("/app/latex/template.tex")


def _is_markdown(text: str) -> bool:
    return bool(re.search(r"^#{1,3} ", text, re.MULTILINE))


# ---------------------------------------------------------------------------
# LaTeX figure extraction
# ---------------------------------------------------------------------------

def _extract_latex_figures(text: str) -> list[dict]:
    lines = text.splitlines()
    env_re = re.compile(r"\\begin\{figure\*?\}", re.IGNORECASE)
    end_re = re.compile(r"\\end\{figure\*?\}", re.IGNORECASE)
    cap_re = re.compile(r"\\caption\{((?:[^{}]|\{[^{}]*\})*)\}", re.IGNORECASE)

    figures = []
    depth = 0
    start = None
    idx = 1
    for lineno, line in enumerate(lines):
        if env_re.search(line):
            if depth == 0:
                start = lineno
            depth += 1
        if end_re.search(line):
            depth = max(0, depth - 1)
            if depth == 0 and start is not None:
                block = "\n".join(lines[start : lineno + 1])
                cap_m = cap_re.search(block)
                caption = cap_m.group(1).strip() if cap_m else ""
                caption = re.sub(r"\\[a-zA-Z]+\{([^}]*)\}", r"\1", caption)
                caption = re.sub(r"\\[a-zA-Z]+", "", caption).strip()
                figures.append({
                    "index": idx,
                    "caption": caption,
                    "body": block,
                    "start_line": start + 1,
                    "end_line": lineno + 1,
                })
                idx += 1
                start = None
    return figures


# ---------------------------------------------------------------------------
# Markdown figure extraction — look for ![...](...)  or Figure N: lines
# ---------------------------------------------------------------------------

def _extract_md_figures(text: str) -> list[dict]:
    lines = text.splitlines()
    figures = []
    idx = 1
    img_re = re.compile(r"!\[([^\]]*)\]\([^)]*\)")
    fig_cap_re = re.compile(r"(?:Figure|Fig\.?)\s+\d+[:.]\s*(.+)", re.IGNORECASE)

    i = 0
    while i < len(lines):
        line = lines[i]
        if img_re.search(line) or fig_cap_re.search(line):
            # grab a window: 2 lines before + 3 lines after for context
            start = max(0, i - 2)
            end = min(len(lines) - 1, i + 3)
            block = "\n".join(lines[start : end + 1])
            # try to extract caption from the image alt text or following line
            cap = ""
            m = img_re.search(line)
            if m:
                cap = m.group(1)
            if not cap and i + 1 < len(lines):
                cap = lines[i + 1].strip()
            if not cap:
                fc = fig_cap_re.search(line)
                if fc:
                    cap = fc.group(1).strip()
            figures.append({
                "index": idx,
                "caption": cap,
                "body": block,
                "start_line": start + 1,
                "end_line": end + 1,
            })
            idx += 1
            i = end + 1
        else:
            i += 1
    return figures


def main():
    parser = argparse.ArgumentParser(
        description="Find a figure in the paper under review."
    )
    parser.add_argument("target", nargs="?", default=None,
                        help="Figure number (1, 2, …) or caption keyword")
    parser.add_argument("--list", action="store_true",
                        help="List all figures with captions")
    args = parser.parse_args()

    if not PAPER.is_file():
        print(f"error: {PAPER} not found", file=sys.stderr)
        sys.exit(2)

    text = PAPER.read_text(encoding="utf-8", errors="replace")
    is_md = _is_markdown(text)
    figures = _extract_md_figures(text) if is_md else _extract_latex_figures(text)

    if args.list or args.target is None:
        if not figures:
            print("No figures found in paper.")
            return
        print(f"Figures in paper ({len(figures)} found):\n")
        for f in figures:
            cap = f["caption"] or "(no caption)"
            print(f"  Figure {f['index']}  (lines {f['start_line']}–{f['end_line']})  {cap[:80]}")
        return

    target = args.target.strip()
    match = None
    if target.isdigit():
        n = int(target)
        for f in figures:
            if f["index"] == n:
                match = f
                break
    else:
        q = target.lower()
        for f in figures:
            if q in f["caption"].lower() or q in f["body"].lower():
                match = f
                break

    if match is None:
        print(
            f"error: figure {target!r} not found.\n"
            f"Run `read_figure --list` to see available figures.",
            file=sys.stderr,
        )
        sys.exit(1)

    cap = match["caption"] or "(no caption)"
    print(f"=== Figure {match['index']} (lines {match['start_line']}–{match['end_line']}) ===")
    print(f"Caption: {cap}\n")
    print(match["body"])


if __name__ == "__main__":
    main()
